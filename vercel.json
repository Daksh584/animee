{
  "rewrites": [
    {
      "source": "/api/anikoto/:path*",
      "destination": "https://anikotoapi.site/:path*"
    },
    {
      "source": "/api/tmdb/:path*",
      "destination": "https://api.themoviedb.org/3/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}